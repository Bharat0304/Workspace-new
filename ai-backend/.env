# Test environment configuration
DEBUG=true
PYTHON_PORT=8005
LOG_LEVEL=INFO

# Database (using mock for demo)
MONGODB_URL=
MONGODB_DB_NAME=workspace_ai_test

# Disable auth for testing
ENABLE_AUTH=false
ENABLE_RATE_LIMITING=false
ENABLE_REQUEST_LOGGING=true

# CORS (allow localhost)
FRONTEND_URL=http://localhost:3000

# Cache
URL_CACHE_TTL=60

# Metrics
ENABLE_METRICS=true
