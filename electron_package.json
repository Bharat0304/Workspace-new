{
  "name": "unified-ai-assistant",
  "version": "1.0.0",
  "description": "Unified AI Assistant with Voice and Visual Analysis",
  "main": "electron_main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux"
  },
  "keywords": ["ai", "assistant", "voice", "visual", "productivity", "electron"],
  "author": "AI Assistant Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "form-data": "^4.0.0"
  },
  "build": {
    "appId": "com.aiassistant.unified",
    "productName": "Unified AI Assistant",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron_main.js",
      "preload.js",
      "ai_assistant_server.py",
      "face_landmarker.task",
      "calibration.json",
      "requirements.txt",
      "backend/**/*",
      "frontend/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
