{
  "manifest_version": 3,
  "name": "WorkSpace AI Tab Monitor",
  "version": "1.0.0",
  "description": "Monitors tab content and blocks distracting sites during focus sessions",
  "permissions": [
    "tabs",
    "activeTab", 
    "storage",
    "alarms",
    "notifications",
    "tabCapture"
  ],
  "host_permissions": [
    "http://localhost:8005/*",
    "https://localhost:8005/*"
  ],
  "background": {
    "service_worker": "background_simple.js"
  },
  "action": {
    "default_popup": "popup_simple.html",
    "default_title": "WorkSpace AI Monitor"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png", 
    "128": "icons/icon128.png"
  }
}
