{
  "manifest_version": 3,
  "name": "WorkSpace AI Assistant",
  "version": "1.0.0",
  "description": "AI-powered productivity monitoring and coaching extension",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting",
    "alarms",
    "notifications",
    "desktopCapture",
    "tabCapture"
  ],
  "host_permissions": [
    "http://localhost:8005/*",
    "http://localhost:4001/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "WorkSpace AI"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["injection.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
